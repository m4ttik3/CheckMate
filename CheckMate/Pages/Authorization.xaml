<Page x:Class="CheckMate.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CheckMate.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация"
      Background="#121212">

    <Grid  >
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid   Background="#FF252525" Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Source="/logo.jpg" Width="80" Margin="10" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Foreground="White"  Text="CheckMate" Width="299" FontSize="40" FontFamily="Times New Roman" HorizontalAlignment="Center" VerticalAlignment="Center"  ></TextBlock>
        </Grid>
        <StackPanel  Grid.Row="1" Width="250" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF252525" >
            <TextBlock Foreground="White"  Text="Авторизация" FontSize="24" FontFamily="Times New Roman"  HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="10"></TextBlock>
            <TextBlock Foreground="White"  Text="Логин" Width="200 " FontSize="14" FontFamily="Times New Roman"  ></TextBlock>
            <Border CornerRadius="8" Background="White " Width="200" Height="45">
                <TextBox Background="Transparent"  Foreground="Black" BorderThickness="0"  x:Name="Login" Width="200" Padding="10 " Margin="0,0,0,0" > </TextBox>
            </Border>
            <TextBlock Foreground="White" Text="Пароль" Width="200 " FontSize="14"  FontFamily="Times New Roman" Margin="0,15,0,0"></TextBlock>
            <Border CornerRadius="8" Background="White " Width="200" Height="45" >
            <PasswordBox  x:Name="Password" Background="Transparent" BorderThickness="0"  Foreground="Black"   Width="200" Padding="10" Margin="0,0,0,0"></PasswordBox>
            </Border>
            <Border CornerRadius="8" Background="#007ACC" Width="200" Height="35" Margin="0,30,0,0">
            <Button  Content="Войти" Click="LoginButton_Click" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" Cursor="Hand" Width="200" Height="35" />
            </Border>
            <TextBlock Foreground="Red" Text="" Name="ErrorText" HorizontalAlignment="Center"  VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2"  Background="#FF252525"   >
            <TextBlock Foreground="White"  Text="Telegram" FontSize="19" FontFamily="Times New Roman"  HorizontalAlignment="Center"  VerticalAlignment="Center" Margin="15"/>
        </StackPanel>
    </Grid>
</Page>
